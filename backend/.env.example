# Copiar a backend/.env y ajustar.
# Nunca subir .env al repositorio.

JWT_SECRET=cambiar-por-secreto-largo-en-produccion

# MySQL — base Store
DB_NAME=store
DB_USER=root
DB_PASS=
DB_HOST=localhost
DB_PORT=3306

# Opcional: log SQL de Sequelize (1 = activo)
# DB_LOGGING=0

# Servidor HTTP
PORT=3002
API_PREFIX=storeapi

# Zona horaria por defecto (IANA)
# APP_TIMEZONE=America/Guayaquil

# Gestor SoftEd (pull manual opcional; runtime usa app_entitlements local)
SUBSCRIPTION_API_URL=http://127.0.0.1:3000/gestor-proyectos-negocios/api
SUBSCRIPTION_API_KEY=

# Debe coincidir con Apps.entitlement_secret del gestor para esta app
GESTOR_SYNC_SECRET=store_gestor_sync_local_dev
